# =============================================================================
# versions.env — Pinned component versions for this release
# =============================================================================
# This file declares the exact upstream versions bundled in this release.
# CI/CD reads this file for automated builds. Edit before tagging a new release.
#
# Version tag format: {agent_date}-{webui_semver}
# Example:            2026.4.30-0.50.266
#
# CONTAINER_RUNTIME controls which container runtime the helper scripts use.
#   auto         — detect podman first, fall back to docker (default)
#   podman       — always use podman / podman-compose
#   docker       — always use docker / docker compose
#   docker-nolog — always use docker / docker compose (logs to /dev/null)
#
# USE_SUDO controls whether commands are run with sudo.
#   false — run commands directly (default, for rootless podman or docker group users)
#   true  — prefix commands with sudo (for rootful podman/docker)
#
# ENABLE_WHATSAPP_BRIDGE controls whether the WhatsApp bridge is included in the image.
#   false — remove WhatsApp bridge at build time (default, recommended)
#   true  — keep WhatsApp bridge in the image
#   Note: Requires WHATSAPP_ALLOWED_USERS to be configured before use.
#   See https://github.com/NousResearch/hermes-agent/issues/15108
# =============================================================================

AGENT_VERSION=v2026.6.19
WEBUI_VERSION=v0.51.742
CONTAINER_RUNTIME=auto
USE_SUDO=false
ENABLE_WHATSAPP_BRIDGE=false
