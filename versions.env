# =============================================================================
# versions.env — Pinned component versions and runtime settings
#
# This file is the single source of truth for which hermes-agent and
# hermes-webui versions are built into the container image.
#
# build.sh, up.sh, and down.sh all read from this file.
# =============================================================================

# ---------------------------------------------------------------------------
# Component versions (pinned for reproducible builds)
# ---------------------------------------------------------------------------
AGENT_VERSION=v2026.7.7.2
WEBUI_VERSION=v0.51.943

# ---------------------------------------------------------------------------
# Runtime selector
# ---------------------------------------------------------------------------
# Controls which container runtime the helper scripts (build.sh, up.sh,
# down.sh) use.
#
#   auto         — detect podman first, fall back to docker (default)
#   podman       — use podman / podman-compose
#   docker       — use docker / docker compose
#   docker-nolog — same as docker but suppresses log output
#
CONTAINER_RUNTIME=auto

# ---------------------------------------------------------------------------
# Sudo mode
# ---------------------------------------------------------------------------
# Set to true to run docker/podman commands with sudo (rootful mode).
# Rootless Podman and Docker (user in docker group) should use false.
#
USE_SUDO=false

# ---------------------------------------------------------------------------
# WhatsApp bridge
# ---------------------------------------------------------------------------
# The WhatsApp bridge is NOT included in the image by default for security
# reasons. Set to true to include it at build time.
# See: https://github.com/NousResearch/hermes-agent/issues/15108
#
ENABLE_WHATSAPP_BRIDGE=false

# ---------------------------------------------------------------------------
# Dashboard credentials
# ---------------------------------------------------------------------------
# Since hermes-agent v2026.7.1, the dashboard requires authentication.
# Set the login credentials for the dashboard here.
#
#   admin:admin    — default, works immediately (change for internet exposure)
#   auto           — auto-generate a random password, printed by ./up.sh
#   user:password  — your own username:password pair
#
DASHBOARD_CREDENTIAL=admin:admin
