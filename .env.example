# =============================================================================
# .env.example — Hermes Suit Configuration
# Copy to .env and fill in your values. This file is for reference only;
# the actual config lives in ~/.hermes/.env and ~/.hermes/config.yaml
# which are mounted into the container.
# =============================================================================

# --- UID/GID for Podman user namespace mapping ---
# Set these to match your WSL user to avoid permission issues.
# Find with: id -u   and   id -g
HERMES_UID=1000
HERMES_GID=1000
